# Edge Function secrets — set with: supabase secrets set KEY=value
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are provided automatically by Supabase.)

# ── Steps ingest (well2go-steps-ingest) ──
# A shared secret your iOS Shortcut must send as ?token=... — make up any random string.
INGEST_TOKEN=change-me-to-a-random-string
# Fallback athlete name when the Shortcut doesn't send one. Match config.js `athlete`.
INGEST_DEFAULT_ATHLETE=me

# ── AI vision (meal / water / technogym / bodycomp) ──
# OpenRouter API key — https://openrouter.ai/keys  (these 4 functions won't work without it)
OPENROUTER_API_KEY=sk-or-...
# Optional: override the vision model (default qwen/qwen3-vl-235b-a22b-instruct)
# VL_MODEL=qwen/qwen3-vl-235b-a22b-instruct

# ── Strava sync (well2go-strava-sync) — optional, only if you want workout auto-import ──
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
STRAVA_ATHLETE=me
